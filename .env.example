# ─────────────────────────────────────────────────────────────
#  PollCraft – Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=polluser
POSTGRES_PASSWORD=pollpassword          # change in production
POSTGRES_DB=polldb
POSTGRES_PORT=5432                      # host port (container always uses 5432)

# ── Backend ───────────────────────────────────────────────────
NODE_ENV=development                    # development | production
BACKEND_PORT=5000
JWT_SECRET=supersecretjwtkey_changeme   # MUST change in production (min 32 chars)
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000      # used for CORS

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# ── Share links (LAN access from phone/other devices) ─────────
# Set this to your computer's local IP so share links work on phones
# Run: ipconfig (Windows) | ifconfig (Mac/Linux) → look for IPv4
# Example: VITE_HOST_IP=192.168.1.3
VITE_HOST_IP=
